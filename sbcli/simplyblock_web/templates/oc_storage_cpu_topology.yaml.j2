apiVersion: batch/v1
kind: Job
metadata:
  name: {{ CORE_JOBNAME }}
  namespace: {{ NAMESPACE }}
spec:
  template:
    spec:
      restartPolicy: OnFailure
      nodeSelector:
        kubernetes.io/hostname: {{ HOSTNAME }}
      hostNetwork: true
      hostPID: true
      serviceAccountName: simplyblock-storage-node-sa
      tolerations:
        - effect: NoSchedule
          operator: Exists
        - effect: NoExecute
          operator: Exists
      volumes:
        - name: var-simplyblock
          hostPath:
            path: /var/simplyblock
      containers:
        - name: init-setup
          image: alpine/kubectl:1.34.1
          securityContext:
            privileged: true
          volumeMounts:
            - name: var-simplyblock
              mountPath: /var/simplyblock
          command: ["/bin/sh", "-c"]
          args:
            - |
              set -e
              MARKER="/var/simplyblock/.cpu_topology_applied"
              if [ -f "$MARKER" ]; then
                  echo "[INFO] Node already configured. Waiting for NUMA plugin pod to be ready..."
                  RETRIES=0
                  while [ $RETRIES -lt 36 ]; do
                    PLUGIN_READY=$(kubectl get pod -n kube-system \
                      --field-selector spec.nodeName={{ HOSTNAME }} \
                      -l app=simplyblock-numa-resource-plugin \
                      -o jsonpath='{.items[0].status.containerStatuses[0].ready}' 2>/dev/null || true)
                    NUMA_ALLOC=$(kubectl get node "{{ HOSTNAME }}" \
                      -o jsonpath='{.status.allocatable.numa-align/numa-{{ NSOCKET }}}' 2>/dev/null || true)
                    if [ "$PLUGIN_READY" = "true" ] && [ "$NUMA_ALLOC" = "100" ]; then
                      echo "[INFO] NUMA plugin is ready and numa-align/numa-{{ NSOCKET }} is available (100)"
                      exit 0
                    fi
                    RETRIES=$((RETRIES + 1))
                    echo "[INFO] Waiting for NUMA readiness (plugin=$PLUGIN_READY, allocatable=$NUMA_ALLOC), retry $RETRIES/36 in 10s..."
                    sleep 10
                  done
                  echo "[ERROR] NUMA plugin did not become ready after 6 minutes"
                  exit 1
              fi

              # Resource names — one MCP/MC/KC shared across all storage nodes in the cluster.
              # The MCP nodeSelector grows as new nodes are added (In operator).
              MCP_NAME="storage-{{ CLUSTER_ID }}"
              MC_NAME="storage-mc-{{ CLUSTER_ID }}"
              KC_NAME="storage-kubelet-{{ CLUSTER_ID }}"
              KC_LABEL="storage-cpumanager-{{ CLUSTER_ID }}"
              HOSTNAME="{{ HOSTNAME }}"

              # ---- MachineConfigPool ----------------------------------------
              if kubectl get machineconfigpool "$MCP_NAME" > /dev/null 2>&1; then
                echo "[INFO] MCP $MCP_NAME already exists — appending $HOSTNAME to nodeSelector"
                EXISTING=$(kubectl get machineconfigpool "$MCP_NAME" \
                  -o jsonpath='{.spec.nodeSelector.matchExpressions[?(@.key=="kubernetes.io/hostname")].values}')
                if echo "$EXISTING" | grep -q "$HOSTNAME"; then
                  echo "[INFO] $HOSTNAME already in MCP nodeSelector, skipping patch"
                else
                  kubectl patch machineconfigpool "$MCP_NAME" --type=json \
                    -p "[{\"op\": \"add\", \"path\": \"/spec/nodeSelector/matchExpressions/0/values/-\", \"value\": \"$HOSTNAME\"}]"
                  echo "[INFO] Added $HOSTNAME to MCP $MCP_NAME"
                fi
              else
                echo "[INFO] Creating MCP $MCP_NAME for $HOSTNAME"
                cat <<MCPEOF | kubectl apply -f -
              apiVersion: machineconfiguration.openshift.io/v1
              kind: MachineConfigPool
              metadata:
                name: $MCP_NAME
                labels:
                  custom-kubelet: $KC_LABEL
              spec:
                machineConfigSelector:
                  matchExpressions:
                    - key: machineconfiguration.openshift.io/role
                      operator: In
                      values:
                        - worker
                        - $MCP_NAME
                nodeSelector:
                  matchExpressions:
                    - key: kubernetes.io/hostname
                      operator: In
                      values:
                        - $HOSTNAME
                maxUnavailable: 1
              MCPEOF
              fi

              # ---- MachineConfig --------------------------------------------
              # Role matches MCP name so MCO-generated KubeletConfig MC is also picked up.
              if kubectl get machineconfig "$MC_NAME" > /dev/null 2>&1; then
                echo "[INFO] MC $MC_NAME already exists — skipping"
              else
                echo "[INFO] Creating MC $MC_NAME"
                cat <<MCEOF | kubectl apply -f -
              apiVersion: machineconfiguration.openshift.io/v1
              kind: MachineConfig
              metadata:
                name: $MC_NAME
                labels:
                  machineconfiguration.openshift.io/role: $MCP_NAME
              spec:
                config:
                  ignition:
                    version: 3.2.0
              MCEOF
              fi

              # ---- KubeletConfig --------------------------------------------
              if kubectl get kubeletconfig "$KC_NAME" > /dev/null 2>&1; then
                echo "[INFO] KubeletConfig $KC_NAME already exists — skipping"
              else
                echo "[INFO] Creating KubeletConfig $KC_NAME"
                cat <<KCEOF | kubectl apply -f -
              apiVersion: machineconfiguration.openshift.io/v1
              kind: KubeletConfig
              metadata:
                name: $KC_NAME
              spec:
                machineConfigPoolSelector:
                  matchLabels:
                    custom-kubelet: $KC_LABEL
                kubeletConfig:
                  cpuManagerPolicy: static
                  cpuManagerReconcilePeriod: 5s
                  topologyManagerPolicy: single-numa-node
                  reservedSystemCPUs: {{ RESERVED_SYSTEM_CPUS }}
              KCEOF
              fi

              echo "[INFO] Marking node as configured."
              touch "$MARKER"

              echo "[INFO] Node is updating the kubeletconfig, waiting for reboot..."
              sleep 900
